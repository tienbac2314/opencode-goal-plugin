{
  "name": "@prevalentware/opencode-goal-plugin",
  "version": "0.1.0",
  "type": "module",
  "description": "Codex-style long-running goal mode for OpenCode.",
  "license": "MIT",
  "author": "Prevalentware",
  "repository": {
    "type": "git",
    "url": "https://github.com/prevalentWare/opencode-goal-plugin"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "opencode",
    "opencode-plugin",
    "goal",
    "agent",
    "tui"
  ],
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "exports": {
    "./server": {
      "import": "./dist/server.js"
    },
    "./tui": {
      "import": "./dist/tui.js"
    }
  },
  "scripts": {
    "clean": "rm -rf dist",
    "build": "bun run clean && bun build ./src/server.ts ./src/tui.tsx --outdir ./dist --target bun --external @opencode-ai/plugin --external @opencode-ai/plugin/tui --external @opentui/core --external @opentui/solid --external solid-js --external zod",
    "ci:version": "bun scripts/resolve-ci-version.ts",
    "lint": "eslint .",
    "pack:dry-run": "npm pack --dry-run",
    "test": "bun test",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "bun run test && bun run build"
  },
  "engines": {
    "opencode": ">=1.14.0"
  },
  "dependencies": {
    "@opencode-ai/plugin": "^1.14.39",
    "@opentui/core": "^0.2.2",
    "@opentui/solid": "^0.2.2",
    "solid-js": "1.9.12",
    "zod": "^4.1.8"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/bun": "^1.3.13",
    "eslint": "^10.3.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.2"
  }
}
